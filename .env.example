# Project isolation.
PROJECT_ID=clearcut

# Credit consume strategy.
CREDIT_CONSUME_ORDER=monthly,purchased,gifted

# Background removal provider.
# auto priority: Photoroom -> BRIA -> remove.bg
BACKGROUND_REMOVAL_PROVIDER=auto

# Photoroom API: low-cost default cloud provider.
PHOTOROOM_API_KEY=

# BRIA API: configure BRIA_API_URL according to your BRIA account/API gateway.
BRIA_API_KEY=
BRIA_API_URL=

# Remove.bg API: premium fallback.
# Get yours at: https://www.remove.bg/api
REMOVE_BG_API_KEY=

# Google OAuth
# Get yours at: https://console.cloud.google.com/apis/credentials
APP_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT Secret (随机生成: openssl rand -hex 32)
JWT_SECRET=

# Payment platform used by the pricing page.
# paypal = PayPal JS buttons, creem = Creem hosted checkout.
NEXT_PUBLIC_PAYMENT_PLATFORM=paypal

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Creem
# CREEM_TEST_MODE=true uses https://test-api.creem.io unless CREEM_API_BASE is set.
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_TEST_MODE=true
CREEM_API_BASE=

# Mock Stripe / Creem fallback for local tests only.
# Do not enable in production.
PAYMENT_MOCK_ENABLED=false
